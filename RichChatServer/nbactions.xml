<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <action>
        <actionName>run</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>spring-boot:run</goal>
        </goals>
        <properties>
            <run.jvmArguments>-noverify -XX:TieredStopAtLevel=1 </run.jvmArguments>
            <run.mainClass>richChatServer.Rich Chat ServerApplication</run.mainClass>
            <Env.SPRING_OUTPUT_ANSI_ENABLED>always</Env.SPRING_OUTPUT_ANSI_ENABLED>
        </properties>
    </action>
    <action>
        <actionName>debug</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>spring-boot:run</goal>
        </goals>
        <properties>
            <run.jvmArguments>-Xdebug -Xrunjdwp:transport=dt_socket,server=n,address=${jpda.address} -noverify -XX:TieredStopAtLevel=1 </run.jvmArguments>
            <run.mainClass>richChatServer.Rich Chat ServerApplication</run.mainClass>
            <Env.SPRING_OUTPUT_ANSI_ENABLED>always</Env.SPRING_OUTPUT_ANSI_ENABLED>
            <jpda.listen>true</jpda.listen>
        </properties>
    </action>
    <action>
        <actionName>profile</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:1.2.1:exec</goal>
        </goals>
        <properties>
            <exec.args>-classpath %classpath richChatServer.Rich Chat ServerApplication</exec.args>
            <exec.executable>java</exec.executable>
        </properties>
    </action>
    <action>
        <actionName>CUSTOM-Generate all documentation</actionName>
        <displayName>Generate all documentation</displayName>
        <goals>
            <goal>site</goal>
        </goals>
    </action>
    <action>
        <actionName>CUSTOM-Clean and Build without test</actionName>
        <displayName>Clean and Build without test</displayName>
        <goals>
            <goal>clean</goal>
            <goal>install</goal>
        </goals>
        <properties>
            <maven.test.skip>true</maven.test.skip>
        </properties>
    </action>
    <action>
        <actionName>CUSTOM-purge local repository</actionName>
        <displayName>purge local repository</displayName>
        <goals>
            <goal>dependency:purge-local-repository</goal>
        </goals>
    </action>
</actions>
